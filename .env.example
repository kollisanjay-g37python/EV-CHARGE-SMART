# .env.example
# Copy to .env and fill in your API keys.
# cp .env.example .env

# ── Open Charge Map ───────────────────────────────────────────────────────────
# Register at: https://openchargemap.org/site/develop/api
OPEN_CHARGE_MAP_API_KEY=your_ocm_key_here

# ── TomTom Traffic ────────────────────────────────────────────────────────────
# Register at: https://developer.tomtom.com/traffic-api
TOMTOM_API_KEY=your_tomtom_key_here

# ── Google Maps (Directions) ──────────────────────────────────────────────────
# Register at: https://developers.google.com/maps/documentation/directions/get-api-key
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# ── OpenWeatherMap ────────────────────────────────────────────────────────────
# Register at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_owm_key_here

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Streamlit ─────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Email Alerts (optional) ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ── Slack Alerts (optional) ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ── Redis (optional, for distributed cache) ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0
